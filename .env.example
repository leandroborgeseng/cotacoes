# SQLite — desenvolvimento local (arquivo em prisma/)
DATABASE_URL="file:./prisma/dev.db"

# Docker / Railway (produção): volume com mount path /app/data — mesmo caminho do Dockerfile:
# DATABASE_URL="file:/app/data/cotacoes.db"
# Sem volume persistente, cada redeploy apaga o SQLite dentro do container.
# Primeira vez: `npx prisma db seed` manual (ou cadastre pelo admin). O boot não roda seed.

# Painel admin: senha fixa no código (src/lib/password.ts). JWT tem fallback em código;
# defina ADMIN_JWT_SECRET (≥16 chars) em produção se quiser trocar o segredo de assinatura.
# ADMIN_JWT_SECRET="troque-por-uma-chave-longa-aleatoria"

# Opcional: seed apaga tudo e recria (só dev). Sem isso, o seed só garante hospital/convite demo.
# SEED_RESET="true"

# URL pública do site (links nos e-mails de confirmação ao fornecedor). Em Vercel pode omitir se VERCEL_URL bastar.
# NEXT_PUBLIC_APP_URL="https://seu-dominio.com"

# E-mail (Resend): após enviar a cotação, o fornecedor recebe agradecimento + link /minha-cotacao/...
# https://resend.com — crie API key e um remetente verificado (domínio próprio em produção).
# RESEND_API_KEY="re_..."
# RESEND_FROM="Pré-cotação <cotacao@seudominio.com>"
